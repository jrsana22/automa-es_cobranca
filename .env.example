# Automação Cobrança - Variáveis de Ambiente

# Segurança
SECRET_KEY=change-me-to-a-random-string
ENCRYPTION_KEY=change-me-to-a-random-32-byte-key

# Google Sheets Service Account
GOOGLE_CREDENTIALS_PATH=~/credentials.json

# Banco de dados
# SQLite (dev): sqlite:///./automacao.db
# PostgreSQL (prod): postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./automacao.db

# App
APP_HOST=0.0.0.0
APP_PORT=8000

# Webhook n8n para notificações WhatsApp (obrigatório para envio funcionar)
N8N_WEBHOOK_URL=https://seu-n8n.com/webhook/automacao-cobranca